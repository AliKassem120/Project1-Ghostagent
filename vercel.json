{
    "installCommand": "pnpm install --no-frozen-lockfile",
    "functions": {
        "src/app/api/webhook/instagram/route.ts": {
            "maxDuration": 60
        },
        "src/app/api/webhook/whatsapp/route.ts": {
            "maxDuration": 60
        },
        "src/app/api/worker/process/route.ts": {
            "maxDuration": 60
        }
    },
    "crons": [
        {
            "path": "/api/cron/purge",
            "schedule": "0 0 * * 0"
        }
    ]
}